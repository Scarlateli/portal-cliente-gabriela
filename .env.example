# Copie para .env e preencha quando for conectar o backend.
# O .env NÃO é versionado (ver .gitignore).

# Fonte de dados: "mock" (em memória, padrão) ou "supabase"
VITE_DATA_SOURCE=mock

# Supabase (use a URL do projeto e a chave ANON — pública, protegida por RLS).
# NUNCA coloque a service_role key no front-end.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
